{{ 'section-scene-shift.css' | asset_url | stylesheet_tag }}

{%- comment -%} GSAP + ScrollTrigger for scroll-driven drawer transition {%- endcomment -%}
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
{%- comment -%} Lottie player for scroll-driven mascot animations {%- endcomment -%}
<script src="https://cdnjs.cloudflare.com/ajax/libs/lottie-web/5.12.2/lottie.min.js" defer></script>
<script src="{{ 'scene-shift-scroll.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'scene-shift.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  #SceneShift-{{ section.id }} {
    --scene-shift-radius: {{ section.settings.card_radius }}px;
    --scene-shift-transition-ms: {{ section.settings.transition_duration }}ms;
    --scene-shift-breathe-ms: {{ section.settings.breathe_duration }}ms;
    --scene-shift-shadow: {{ section.settings.card_shadow | divided_by: 100.0 }};
  }
{%- endstyle -%}

<section
  id="SceneShift-{{ section.id }}"
  class="scene-shift"
  data-section-type="scene-shift"
  data-section-id="{{ section.id }}"
  data-autoplay="{{ section.settings.autoplay }}"
  data-interval="{{ section.settings.autoplay_interval | times: 1000 }}"
  data-pause="{{ section.settings.initial_pause | times: 1000 }}"
  data-breathe="{{ section.settings.breathe_duration }}"
  role="region"
  aria-label="{{ section.settings.heading | default: 'Scene showcase' | escape }}"
>
  {%- comment -%} Scroll-driven cat & dog mascots — left/right corners {%- endcomment -%}
  <div class="scene-shift__mascot scene-shift__mascot--cat" aria-hidden="true" data-lottie-src="{{ 'Loader cat.json' | asset_url }}"></div>
  <div class="scene-shift__mascot scene-shift__mascot--dog" aria-hidden="true" data-lottie-src="{{ 'Cute Doggie.json' | asset_url }}"></div>

  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="scene-shift__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="scene-shift__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="scene-shift__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="scene-shift__carousel">
    <div class="scene-shift__track{% if section.settings.card_shadow == 0 %} scene-shift__track--no-shadow{% endif %}">
      {%- for block in section.blocks -%}
        <div
          class="scene-shift__slide{% if forloop.first %} is-active{% endif %}"
          data-block-id="{{ block.id }}"
          aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
          {{ block.shopify_attributes }}
        >
          {%- comment -%} ── Desktop Base Layer ── {%- endcomment -%}
          <div class="scene-shift__layer scene-shift__layer--base scene-shift__layer--desktop">
            {%- if block.settings.desktop_base_image != blank -%}
              {{
                block.settings.desktop_base_image
                | image_url: width: 2400
                | image_tag:
                  widths: '600, 900, 1200, 1800, 2400',
                  sizes: '(min-width: 1200px) 1200px, 100vw',
                  loading: 'lazy',
                  class: 'scene-shift__image'
              }}
            {%- else -%}
              <div class="scene-shift__placeholder">
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} ── Desktop Shift Layer ── {%- endcomment -%}
          <div class="scene-shift__layer scene-shift__layer--shift scene-shift__layer--desktop">
            {%- if block.settings.desktop_shift_image != blank -%}
              {{
                block.settings.desktop_shift_image
                | image_url: width: 2400
                | image_tag:
                  widths: '600, 900, 1200, 1800, 2400',
                  sizes: '(min-width: 1200px) 1200px, 100vw',
                  loading: 'lazy',
                  class: 'scene-shift__image'
              }}
            {%- endif -%}
          </div>

          {%- comment -%} ── Mobile Base Layer ── {%- endcomment -%}
          <div class="scene-shift__layer scene-shift__layer--base scene-shift__layer--mobile">
            {%- if block.settings.mobile_base_image != blank -%}
              {{
                block.settings.mobile_base_image
                | image_url: width: 1200
                | image_tag:
                  widths: '375, 550, 750, 1000, 1200',
                  sizes: '100vw',
                  loading: 'lazy',
                  class: 'scene-shift__image'
              }}
            {%- elsif block.settings.desktop_base_image != blank -%}
              {{
                block.settings.desktop_base_image
                | image_url: width: 1200
                | image_tag:
                  widths: '375, 550, 750, 1000, 1200',
                  sizes: '100vw',
                  loading: 'lazy',
                  class: 'scene-shift__image'
              }}
            {%- else -%}
              <div class="scene-shift__placeholder">
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} ── Mobile Shift Layer ── {%- endcomment -%}
          <div class="scene-shift__layer scene-shift__layer--shift scene-shift__layer--mobile">
            {%- if block.settings.mobile_shift_image != blank -%}
              {{
                block.settings.mobile_shift_image
                | image_url: width: 1200
                | image_tag:
                  widths: '375, 550, 750, 1000, 1200',
                  sizes: '100vw',
                  loading: 'lazy',
                  class: 'scene-shift__image'
              }}
            {%- elsif block.settings.desktop_shift_image != blank -%}
              {{
                block.settings.desktop_shift_image
                | image_url: width: 1200
                | image_tag:
                  widths: '375, 550, 750, 1000, 1200',
                  sizes: '100vw',
                  loading: 'lazy',
                  class: 'scene-shift__image'
              }}
            {%- endif -%}
          </div>

          {%- comment -%} ── Gradient Overlay ── {%- endcomment -%}
          <div class="scene-shift__overlay"></div>

          {%- comment -%} ── Content ── {%- endcomment -%}
          <div class="scene-shift__content">
            {%- if block.settings.scene_title != blank -%}
              <h3 class="scene-shift__title">{{ block.settings.scene_title }}</h3>
            {%- endif -%}

            {%- if block.settings.scene_caption != blank -%}
              <p class="scene-shift__caption">{{ block.settings.scene_caption }}</p>
            {%- endif -%}

            {%- if block.settings.button_label != blank -%}
              <a
                class="scene-shift__cta"
                {% if block.settings.button_link != blank %}href="{{ block.settings.button_link }}"{% endif %}
                {% if block.settings.button_link == blank %}role="link" aria-disabled="true"{% endif %}
              >
                {{ block.settings.button_label }}
                <svg class="scene-shift__cta-arrow" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M3.5 8H12.5M12.5 8L8.5 4M12.5 8L8.5 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}

      {%- if section.blocks.size == 0 -%}
        <div class="scene-shift__placeholder">
          <p>Add scene card blocks in the theme editor</p>
        </div>
      {%- endif -%}

      {%- comment -%} ── Navigation Arrows ── {%- endcomment -%}
      {%- if section.blocks.size > 1 -%}
        <button
          class="scene-shift__nav scene-shift__nav--prev{% unless section.settings.show_arrows %} scene-shift__nav--hidden{% endunless %}"
          aria-label="{{ 'accessibility.previous_slide' | t }}"
          disabled
        >
          <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <button
          class="scene-shift__nav scene-shift__nav--next{% unless section.settings.show_arrows %} scene-shift__nav--hidden{% endunless %}"
          aria-label="{{ 'accessibility.next_slide' | t }}"
        >
          <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      {%- endif -%}
    </div>

    {%- comment -%} ── Pagination Dots ── {%- endcomment -%}
    {%- if section.blocks.size > 1 -%}
      <div class="scene-shift__dots{% unless section.settings.show_dots %} scene-shift__dots--hidden{% endunless %}" role="tablist" aria-label="Scene navigation">
        {%- for block in section.blocks -%}
          <button
            class="scene-shift__dot{% if forloop.first %} is-active{% endif %}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-label="Scene {{ forloop.index }}: {{ block.settings.scene_title | default: 'Untitled' | escape }}"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Scene Shift",
  "tag": "section",
  "class": "section-scene-shift",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Where the Shift Begins"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Small, thoughtful changes that turn everyday corners into spaces that hold how you feel."
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "label": "Autoplay interval (seconds)",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8,
      "unit": "s"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "initial_pause",
      "label": "Initial pause before breathing (seconds)",
      "min": 1,
      "max": 5,
      "step": 0.5,
      "default": 2,
      "unit": "s"
    },
    {
      "type": "range",
      "id": "breathe_duration",
      "label": "Breathing animation duration (ms)",
      "min": 2000,
      "max": 8000,
      "step": 500,
      "default": 4000,
      "unit": "ms"
    },
    {
      "type": "range",
      "id": "transition_duration",
      "label": "Card transition duration (ms)",
      "min": 400,
      "max": 1600,
      "step": 100,
      "default": 800,
      "unit": "ms"
    },
    {
      "type": "header",
      "content": "Controls"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show pagination dots",
      "default": true
    },
    {
      "type": "header",
      "content": "Card Style"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 48,
      "step": 2,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "card_shadow",
      "label": "Card shadow intensity",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 30,
      "unit": "%"
    }
  ],
  "blocks": [
    {
      "type": "scene_card",
      "name": "Scene Card",
      "settings": [
        {
          "type": "header",
          "content": "Desktop Images"
        },
        {
          "type": "image_picker",
          "id": "desktop_base_image",
          "label": "Desktop — Base layer"
        },
        {
          "type": "image_picker",
          "id": "desktop_shift_image",
          "label": "Desktop — Shift layer"
        },
        {
          "type": "header",
          "content": "Mobile Images"
        },
        {
          "type": "image_picker",
          "id": "mobile_base_image",
          "label": "Mobile — Base layer",
          "info": "Falls back to desktop image if not set"
        },
        {
          "type": "image_picker",
          "id": "mobile_shift_image",
          "label": "Mobile — Shift layer",
          "info": "Falls back to desktop image if not set"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "scene_title",
          "label": "Scene title",
          "default": "A Quiet Bedroom Corner"
        },
        {
          "type": "textarea",
          "id": "scene_caption",
          "label": "Emotional caption",
          "default": "A few soft essentials that turn rest into ritual."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Explore the Space"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scene Shift",
      "blocks": [
        {
          "type": "scene_card",
          "settings": {
            "scene_title": "A Quiet Bedroom Corner",
            "scene_caption": "A few soft essentials that turn rest into ritual.",
            "button_label": "Explore the Space"
          }
        },
        {
          "type": "scene_card",
          "settings": {
            "scene_title": "A Living Room That Breathes",
            "scene_caption": "Where the light, the texture, and the warmth finally align.",
            "button_label": "See the Full Setup"
          }
        },
        {
          "type": "scene_card",
          "settings": {
            "scene_title": "Your Reading Nook, Awakened",
            "scene_caption": "The corner you always had — now holding exactly how you feel.",
            "button_label": "Enter This Mood"
          }
        }
      ]
    }
  ]
}
{% endschema %}
