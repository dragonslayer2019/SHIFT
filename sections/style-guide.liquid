<section class="section-style-guide color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <div class="style-guide">

      <!-- Hero -->
      <header class="style-guide__hero">
        <p class="style-guide__eyebrow">Design System</p>
        <h1 class="style-guide__hero-title">From still<br>to alive.</h1>
        <p class="style-guide__hero-desc">
          The visual language of SHIFT &mdash; where cold becomes warm,
          numb becomes vivid, and every surface is an invitation to feel something.
        </p>
      </header>

      <!-- 01 Typography -->
      <section class="style-guide__section" id="sg-typography">
        <header class="style-guide__section-header">
          <span class="style-guide__section-number">01</span>
          <h2 class="style-guide__section-title">Typography</h2>
          <p class="style-guide__section-desc">
            Bold headings that land. Body text that breathes.
            Every weight and size sets the mood.
          </p>
        </header>
        <div class="style-guide__type-list">
          <div class="style-guide__type-row">
            <p class="style-guide__type-sample style-guide__type-sample--h1">Wake up your space</p>
            <p class="style-guide__type-meta">H1 · clamp(2.25rem, 5vw, 3.5rem)</p>
          </div>
          <div class="style-guide__type-row">
            <p class="style-guide__type-sample style-guide__type-sample--h2">Light shifts everything</p>
            <p class="style-guide__type-meta">H2 · clamp(1.75rem, 3.5vw, 2.5rem)</p>
          </div>
          <div class="style-guide__type-row">
            <p class="style-guide__type-sample style-guide__type-sample--h3">Small object, big feeling</p>
            <p class="style-guide__type-meta">H3 · clamp(1.25rem, 2.5vw, 1.75rem)</p>
          </div>
          <div class="style-guide__type-row">
            <p class="style-guide__type-sample style-guide__type-sample--h4">Mood is in the details</p>
            <p class="style-guide__type-meta">H4 · clamp(1rem, 2vw, 1.25rem)</p>
          </div>
          <div class="style-guide__type-row">
            <p class="style-guide__type-sample style-guide__type-sample--body-lg">Your home already has a mood. We just help you shift it. A warmer bulb, a different scent, a texture that makes you pause.</p>
            <p class="style-guide__type-meta">Body Large · 1.125rem / 1.7</p>
          </div>
          <div class="style-guide__type-row">
            <p class="style-guide__type-sample style-guide__type-sample--body">Objects that earn their place. Surfaces that feel right. Rituals that turn a room into a refuge.</p>
            <p class="style-guide__type-meta">Body · 0.9375rem / 1.65</p>
          </div>
          <div class="style-guide__type-row">
            <p class="style-guide__type-sample style-guide__type-sample--caption">All tokens adjustable in the Shopify theme editor.</p>
            <p class="style-guide__type-meta">Caption · 0.75rem / 1.5</p>
          </div>
        </div>
      </section>

      <!-- 02 Buttons -->
      <section class="style-guide__section" id="sg-buttons">
        <header class="style-guide__section-header">
          <span class="style-guide__section-number">02</span>
          <h2 class="style-guide__section-title">Buttons</h2>
          <p class="style-guide__section-desc">Pill-shaped, bold, inviting. Primary uses coral — warm enough to feel alive.</p>
        </header>
        <div class="style-guide__btn-grid">
          <div class="style-guide__btn-group">
            <p class="style-guide__btn-group-label">Default</p>
            <div class="style-guide__btn-row">
              <button class="style-guide__btn style-guide__btn--primary" type="button">Shift my mood</button>
              <button class="style-guide__btn style-guide__btn--secondary" type="button">Explore</button>
              <button class="style-guide__btn style-guide__btn--outline" type="button">Learn more</button>
              <button class="style-guide__btn style-guide__btn--ghost" type="button">View all →</button>
            </div>
          </div>
          <div class="style-guide__btn-group">
            <p class="style-guide__btn-group-label">Hover</p>
            <div class="style-guide__btn-row">
              <button class="style-guide__btn style-guide__btn--primary is-hover" type="button">Shift my mood</button>
              <button class="style-guide__btn style-guide__btn--secondary is-hover" type="button">Explore</button>
              <button class="style-guide__btn style-guide__btn--outline is-hover" type="button">Learn more</button>
              <button class="style-guide__btn style-guide__btn--ghost is-hover" type="button">View all →</button>
            </div>
          </div>
          <div class="style-guide__btn-group">
            <p class="style-guide__btn-group-label">Focus</p>
            <div class="style-guide__btn-row">
              <button class="style-guide__btn style-guide__btn--primary is-focus" type="button">Shift my mood</button>
              <button class="style-guide__btn style-guide__btn--outline is-focus" type="button">Learn more</button>
            </div>
          </div>
          <div class="style-guide__btn-group">
            <p class="style-guide__btn-group-label">Disabled</p>
            <div class="style-guide__btn-row">
              <button class="style-guide__btn style-guide__btn--primary" type="button" disabled>Shift my mood</button>
              <button class="style-guide__btn style-guide__btn--secondary" type="button" disabled>Explore</button>
            </div>
          </div>
        </div>
      </section>

      <!-- 03 Cards -->
      <section class="style-guide__section" id="sg-cards">
        <header class="style-guide__section-header">
          <span class="style-guide__section-number">03</span>
          <h2 class="style-guide__section-title">Cards</h2>
          <p class="style-guide__section-desc">Bold color blocks that feel like rooms. Each card is a mood.</p>
        </header>
        <div class="style-guide__card-grid">
          <article class="style-guide__card style-guide__card--coral">
            <span class="style-guide__card-tag">Evening</span>
            <p class="style-guide__card-title">Golden Hour Kit</p>
            <p class="style-guide__card-text">Warm light, soft scent, a quiet corner. Everything to melt the day away.</p>
          </article>
          <article class="style-guide__card style-guide__card--sky">
            <span class="style-guide__card-tag">Morning</span>
            <p class="style-guide__card-title">Fresh Start Bundle</p>
            <p class="style-guide__card-text">Bright, crisp, awake. A scene that makes getting up worth it.</p>
          </article>
          <article class="style-guide__card style-guide__card--cream">
            <span class="style-guide__card-tag">Focus</span>
            <p class="style-guide__card-title">Deep Work Corner</p>
            <p class="style-guide__card-text">Minimal distractions, maximum intention. Designed for flow.</p>
          </article>
          <article class="style-guide__card style-guide__card--ink">
            <span class="style-guide__card-tag">Night</span>
            <p class="style-guide__card-title">Wind Down Ritual</p>
            <p class="style-guide__card-text">Dark, hushed, still. Objects that help you cross from awake to asleep.</p>
          </article>
        </div>
      </section>

      <!-- 04 Forms -->
      <section class="style-guide__section" id="sg-forms">
        <header class="style-guide__section-header">
          <span class="style-guide__section-number">04</span>
          <h2 class="style-guide__section-title">Form Elements</h2>
          <p class="style-guide__section-desc">Friendly inputs with generous sizing and clear focus states.</p>
        </header>
        <div class="style-guide__form-grid">
          <div class="style-guide__field">
            <label class="style-guide__label" for="sg-name">Full name</label>
            <input id="sg-name" class="style-guide__input" type="text" placeholder="Enter your name">
            <p class="style-guide__field-hint">Default state</p>
          </div>
          <div class="style-guide__field">
            <label class="style-guide__label" for="sg-focus">Email</label>
            <input id="sg-focus" class="style-guide__input is-focus" type="email" value="hello@shiftspace.co">
            <p class="style-guide__field-hint">Focus state</p>
          </div>
          <div class="style-guide__field style-guide__field--error">
            <label class="style-guide__label" for="sg-error">Email</label>
            <input id="sg-error" class="style-guide__input" type="email" value="invalid@" aria-invalid="true" aria-describedby="sg-error-msg">
            <p class="style-guide__field-error" id="sg-error-msg" role="alert">Please enter a valid email.</p>
          </div>
          <div class="style-guide__field style-guide__field--disabled">
            <label class="style-guide__label" for="sg-disabled">Discount code</label>
            <input id="sg-disabled" class="style-guide__input" type="text" value="Not available" disabled>
            <p class="style-guide__field-hint">Disabled state</p>
          </div>
          <div class="style-guide__field">
            <label class="style-guide__label" for="sg-textarea">Tell us about your space</label>
            <textarea id="sg-textarea" class="style-guide__input" placeholder="What mood are you going for?"></textarea>
          </div>
          <div class="style-guide__field">
            <label class="style-guide__label" for="sg-select">Room type</label>
            <select id="sg-select" class="style-guide__input">
              <option value="">Choose a room</option>
              <option>Bedroom</option>
              <option>Living room</option>
              <option>Home office</option>
            </select>
          </div>
        </div>
        <div class="style-guide__btn-group" style="margin-top: var(--brand-space-lg);">
          <p class="style-guide__btn-group-label">Checkbox &amp; Radio</p>
          <div class="style-guide__check-group">
            <label class="style-guide__check-item"><input type="checkbox" class="style-guide__check-input" checked><span class="style-guide__check-label">Warm lighting</span></label>
            <label class="style-guide__check-item"><input type="checkbox" class="style-guide__check-input"><span class="style-guide__check-label">Ambient scent</span></label>
            <label class="style-guide__check-item"><input type="radio" name="sg-radio" class="style-guide__check-input" checked><span class="style-guide__check-label">Evening mood</span></label>
            <label class="style-guide__check-item"><input type="radio" name="sg-radio" class="style-guide__check-input"><span class="style-guide__check-label">Morning mood</span></label>
          </div>
        </div>
      </section>

      <!-- 05 Feedback -->
      <section class="style-guide__section" id="sg-feedback">
        <header class="style-guide__section-header">
          <span class="style-guide__section-number">05</span>
          <h2 class="style-guide__section-title">Feedback</h2>
          <p class="style-guide__section-desc">Status messages in the SHIFT voice.</p>
        </header>
        <div class="style-guide__alert-stack">
          <div class="style-guide__alert style-guide__alert--info" role="status">
            <div class="style-guide__alert-body"><p class="style-guide__alert-title">Your order is on its way</p><p class="style-guide__alert-text">Packed with care. Shipping notification coming soon.</p></div>
          </div>
          <div class="style-guide__alert style-guide__alert--success" role="status">
            <div class="style-guide__alert-body"><p class="style-guide__alert-title">Mood updated</p><p class="style-guide__alert-text">Your space config is saved. The new vibe is ready.</p></div>
          </div>
          <div class="style-guide__alert style-guide__alert--warning" role="status">
            <div class="style-guide__alert-body"><p class="style-guide__alert-title">Almost gone</p><p class="style-guide__alert-text">Only a few Golden Hour Kits left.</p></div>
          </div>
          <div class="style-guide__alert style-guide__alert--error" role="alert">
            <div class="style-guide__alert-body"><p class="style-guide__alert-title">Something went wrong</p><p class="style-guide__alert-text">Check the fields and try again.</p></div>
          </div>
        </div>
      </section>

      <!-- 06 Primitives -->
      <section class="style-guide__section" id="sg-primitives">
        <header class="style-guide__section-header">
          <span class="style-guide__section-number">06</span>
          <h2 class="style-guide__section-title">Primitives</h2>
          <p class="style-guide__section-desc">Spacing, radius, shadow. Everything alive starts here.</p>
        </header>
        <div class="style-guide__primitives">
          <div class="style-guide__primitive-group">
            <p class="style-guide__primitive-label">Spacing</p>
            <div class="style-guide__spacing-list">
              <div class="style-guide__spacing-row"><p class="style-guide__spacing-label">xs</p><div class="style-guide__spacing-bar style-guide__spacing-bar--xs"></div><p class="style-guide__spacing-value">4px</p></div>
              <div class="style-guide__spacing-row"><p class="style-guide__spacing-label">sm</p><div class="style-guide__spacing-bar style-guide__spacing-bar--sm"></div><p class="style-guide__spacing-value">8px</p></div>
              <div class="style-guide__spacing-row"><p class="style-guide__spacing-label">md</p><div class="style-guide__spacing-bar style-guide__spacing-bar--md"></div><p class="style-guide__spacing-value">16px</p></div>
              <div class="style-guide__spacing-row"><p class="style-guide__spacing-label">lg</p><div class="style-guide__spacing-bar style-guide__spacing-bar--lg"></div><p class="style-guide__spacing-value">24px</p></div>
              <div class="style-guide__spacing-row"><p class="style-guide__spacing-label">xl</p><div class="style-guide__spacing-bar style-guide__spacing-bar--xl"></div><p class="style-guide__spacing-value">40px</p></div>
              <div class="style-guide__spacing-row"><p class="style-guide__spacing-label">2xl</p><div class="style-guide__spacing-bar style-guide__spacing-bar--2xl"></div><p class="style-guide__spacing-value">64px</p></div>
            </div>
          </div>
          <div class="style-guide__primitive-group">
            <p class="style-guide__primitive-label">Radius</p>
            <div class="style-guide__radius-grid">
              <div class="style-guide__radius-card style-guide__radius-card--sm"><p class="style-guide__radius-label">sm</p><p class="style-guide__radius-value">10px</p></div>
              <div class="style-guide__radius-card style-guide__radius-card--md"><p class="style-guide__radius-label">md</p><p class="style-guide__radius-value">20px</p></div>
              <div class="style-guide__radius-card style-guide__radius-card--lg"><p class="style-guide__radius-label">lg</p><p class="style-guide__radius-value">32px</p></div>
              <div class="style-guide__radius-card style-guide__radius-card--pill"><p class="style-guide__radius-label">pill</p><p class="style-guide__radius-value">999px</p></div>
            </div>
          </div>
          <div class="style-guide__primitive-group">
            <p class="style-guide__primitive-label">Shadow</p>
            <div class="style-guide__shadow-grid">
              <div class="style-guide__shadow-card style-guide__shadow-card--none"><p class="style-guide__shadow-label">none</p><p class="style-guide__shadow-value">Flat, grounded</p></div>
              <div class="style-guide__shadow-card style-guide__shadow-card--sm"><p class="style-guide__shadow-label">sm</p><p class="style-guide__shadow-value">Subtle lift</p></div>
              <div class="style-guide__shadow-card style-guide__shadow-card--md"><p class="style-guide__shadow-label">md</p><p class="style-guide__shadow-value">Elevated</p></div>
            </div>
          </div>
        </div>
      </section>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Style Guide",
  "tag": "section",
  "class": "section section-style-guide",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    }
  ]
}
{% endschema %}
